#!/usr/bin/env bash
# Displays all active IPv4 addresses on the local machine

echo "=== Active IPv4 Addresses ==="

# check if 'ip' command exists
if command -v ip >/dev/null 2>&1; then
    ip -4 addr show | awk '/inet / && !/127.0.0.1/ {print $2}' | cut -d/ -f1
else
# Fallback for older systems or environments using hostname
    hostname -I | tr ' ' '\n' | grep -v '^$'
fi
